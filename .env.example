# Go backend origin used by the /rpc/:path* rewrite proxy in next.config.mjs
BACKEND_ORIGIN=http://localhost:8080

# Must match GOOGLE_CLIENT_ID in the torogan-be .env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Canonical production origin (see lib/site.ts) — used for metadataBase,
# JSON-LD, sitemap.xml, and robots.txt. Falls back to https://torogan.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
